# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://sgnqhuoorsdrudvpbzan.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_chave_anonima_do_supabase_aqui

# Service Role Key (CRÍTICO para funcionamento dos redirecionamentos)
# ⚠️  ATENÇÃO: Esta chave está INCORRETA - usando anon key em vez de service_role key
# 🚨 PROBLEMA: Redirecionamentos falham com erro 403 devido a esta configuração
# 
# SOLUÇÃO:
# 1. Acesse: https://supabase.com/dashboard/project/sgnqhuoorsdrudvpbzan/settings/api
# 2. Copie a "service_role key" (NÃO a "anon key")
# 3. Substitua o valor abaixo pela chave real
# 4. Atualize também no ambiente de produção (Vercel)
#
# TEMPORÁRIO (CAUSA ERRO 403):
SUPABASE_SERVICE_ROLE_KEY=sua_chave_service_role_do_supabase_aqui

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://whatsapp.aescoladenegocios.com.br
NEXT_PUBLIC_LINK_BASE_URL=https://whatsapp.aescoladenegocios.com.br

# JWT Secret for custom auth
JWT_SECRET=seu_jwt_secret_para_autenticacao_customizada_aqui

# Environment
NODE_ENV=production

# Optional: Database Direct URL (if using Supabase pooling)
# DATABASE_URL=your_direct_database_connection_string